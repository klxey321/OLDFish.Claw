{
  "name": "oldfish-claw",
  "version": "0.1.0",
  "private": true,
  "description": "OLDFish.Claw Master + Edge control plane for a 4 Edge + 1 Master OpenClaw deployment.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "dev:master": "cross-env OLDFISH_ROLE=master node --import tsx src/index.ts",
    "dev:edge": "cross-env OLDFISH_ROLE=edge node --import tsx src/index.ts",
    "start:master": "cross-env OLDFISH_ROLE=master node dist/index.js",
    "start:edge": "cross-env OLDFISH_ROLE=edge node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2"
  }
}

